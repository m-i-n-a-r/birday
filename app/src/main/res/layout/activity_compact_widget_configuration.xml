<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fadingEdgeLength="@dimen/linear_vertical_margin"
    android:requiresFadingEdge="vertical"
    android:transitionGroup="true">

    <LinearLayout
        android:id="@+id/container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/activity_horizontal_margin"
        tools:context=".activities.CompactWidgetConfigurationActivity">

        <!-- Title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/activity_vertical_margin"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/configurationTitleImage"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:contentDescription="@string/event_details"
                app:srcCompat="@drawable/animated_nav_settings"
                app:tint="?attr/colorPrimary" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/configurationTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawablePadding="@dimen/activity_vertical_margin"
                android:ellipsize="end"
                android:maxLines="1"
                android:padding="@dimen/in_row_padding"
                android:text="@string/widget_configuration_title"
                android:textAlignment="center"
                android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium"
                android:textStyle="bold" />
        </LinearLayout>

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/configurationDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/activity_vertical_margin"
            android:text="@string/widget_configuration_description"
            android:textAlignment="center"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />

        <!-- Background opacity -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/configurationOpacityTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/linear_vertical_margin"
            android:text="@string/compact_widget_opacity_title"
            android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
            android:textSize="@dimen/custom_preference_title_text_size" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/configurationOpacityDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/compact_widget_opacity_description"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textSize="@dimen/custom_preference_subtitle_text_size" />

        <com.google.android.material.slider.Slider
            android:id="@+id/configurationOpacitySlider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/activity_vertical_margin"
            android:stepSize="5"
            android:valueFrom="0"
            android:valueTo="100" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/configurationOpacityValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            tools:text="80%" />

        <!-- Text size -->
        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/linear_vertical_margin"
            android:text="@string/compact_widget_text_size_title"
            android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
            android:textSize="@dimen/custom_preference_title_text_size" />

        <com.google.android.material.slider.Slider
            android:id="@+id/configurationTextSizeSlider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stepSize="1"
            android:valueFrom="8"
            android:valueTo="18" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/configurationTextSizeValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            tools:text="12 sp" />

        <!-- Show contact photos -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/linear_vertical_margin"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/compact_widget_show_photos_title"
                android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                android:textSize="@dimen/custom_preference_title_text_size" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/configurationShowPhotosSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:paddingStart="@dimen/activity_horizontal_margin"
                android:paddingEnd="@dimen/card_margin" />
        </LinearLayout>

        <!-- Preview with dummy data -->
        <FrameLayout
            android:id="@+id/compactWidgetPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="@dimen/linear_vertical_margin"
            android:background="@drawable/snackbar_background">

            <View
                android:id="@+id/compactWidgetPreviewBackground"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#CC000000" />

            <LinearLayout
                android:id="@+id/previewContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/widget_margin">

                <!-- Today's birthday row (highlighted) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#99E53935"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/in_row_padding"
                    android:paddingVertical="0dp">

                    <ImageView
                        android:id="@+id/previewAvatar1"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/next_event"
                        android:src="@drawable/preview_avatar_1" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingHorizontal="@dimen/in_row_padding">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/compact_widget_preview_name_1"
                            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                            android:textColor="#FFFFFFFF" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/compact_widget_preview_date_1"
                            android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                            android:textColor="#B3FFFFFF"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="@dimen/in_row_padding"
                        android:text="@string/compact_widget_preview_age_1"
                        android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                        android:textColor="#B3FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="@dimen/in_row_padding"
                        android:text="@string/compact_widget_today"
                        android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                        android:textColor="@color/red" />
                </LinearLayout>

                <!-- Normal row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/in_row_padding"
                    android:paddingVertical="0dp">

                    <ImageView
                        android:id="@+id/previewAvatar2"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/next_event"
                        android:src="@drawable/preview_avatar_2" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingHorizontal="@dimen/in_row_padding">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/compact_widget_preview_name_2"
                            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                            android:textColor="#FFFFFFFF" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/compact_widget_preview_date_2"
                            android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                            android:textColor="#B3FFFFFF"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="@dimen/in_row_padding"
                        android:text="@string/compact_widget_preview_age_2"
                        android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                        android:textColor="#B3FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="@dimen/in_row_padding"
                        android:text="@string/compact_widget_preview_days_2"
                        android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                        android:textColor="#FFFFFFFF" />
                </LinearLayout>

                <!-- Normal row 3 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/in_row_padding"
                    android:paddingVertical="0dp">

                    <ImageView
                        android:id="@+id/previewAvatar3"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/next_event"
                        android:src="@drawable/preview_avatar_initial" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingHorizontal="@dimen/in_row_padding">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/compact_widget_preview_name_3"
                            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                            android:textColor="#FFFFFFFF" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/compact_widget_preview_date_3"
                            android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                            android:textColor="#B3FFFFFF"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="@dimen/in_row_padding"
                        android:text="@string/compact_widget_preview_age_3"
                        android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                        android:textColor="#B3FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="@dimen/in_row_padding"
                        android:text="@string/compact_widget_preview_days_3"
                        android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                        android:textColor="#FFFFFFFF" />
                </LinearLayout>

            </LinearLayout>
        </FrameLayout>

        <!-- Confirm button -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/configurationConfirmButton"
            style="@style/Widget.Material3.FloatingActionButton.Large.Secondary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="@dimen/activity_vertical_margin"
            android:contentDescription="@android:string/ok"
            app:srcCompat="@drawable/ic_appintro_done" />

    </LinearLayout>
</ScrollView>
